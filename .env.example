# HR Automation – Full Stack Environment Variables
# Copy this file to .env and fill in all values, then run:  docker compose up --build

# ── LLM ───────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your-openai-api-key-here
LLM_MODEL=gpt-4o

# ── Orchestrator ──────────────────────────────────────────────────────────────
AGENT_TIMEOUT=60

# ── HR Helpdesk (Pinecone RAG) ────────────────────────────────────────────────
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX=hr-policies
PINECONE_FAQ_INDEX=hr-faqs

HELPDESK_SUPABASE_URL=https://your-helpdesk-project.supabase.co
HELPDESK_SUPABASE_KEY=your-helpdesk-service-role-key
HELPDESK_SMTP_USER=your-helpdesk-gmail@gmail.com
HELPDESK_SMTP_PASSWORD=your-helpdesk-app-password

# ── Onboarding ────────────────────────────────────────────────────────────────
ONBOARD_SUPABASE_URL=https://your-onboarding-project.supabase.co
ONBOARD_SUPABASE_KEY=your-onboarding-service-role-key
SUPABASE_STORAGE_BUCKET=your-storage-bucket-name
ONBOARD_SMTP_EMAIL=your-onboarding-gmail@gmail.com
ONBOARD_SMTP_PASSWORD=your-onboarding-app-password
REMINDER_DAYS=7
HR_EMAIL=hr@yourcompany.com

# ── Resume Shortlisting ───────────────────────────────────────────────────────
RESUME_SMTP_EMAIL=your-resume-gmail@gmail.com
RESUME_SMTP_PASSWORD=your-resume-app-password

# ── Attendance ────────────────────────────────────────────────────────────────
ATTENDANCE_SUPABASE_URL=https://your-attendance-project.supabase.co
ATTENDANCE_SUPABASE_KEY=your-attendance-service-role-key
ATTENDANCE_EMAIL_USER=your-attendance-gmail@gmail.com
ATTENDANCE_EMAIL_PASS=your-attendance-app-password

# ── Offboarding (reuses onboarding Supabase + SMTP) ──────────────────────────
# Uses ONBOARD_SUPABASE_URL, ONBOARD_SUPABASE_KEY, ONBOARD_SMTP_EMAIL, ONBOARD_SMTP_PASSWORD
COMPANY_NAME=Your Company Name

# ── Payroll ───────────────────────────────────────────────────────────────────
PAYROLL_SUPABASE_URL=https://your-payroll-project.supabase.co
PAYROLL_SUPABASE_KEY=your-payroll-service-role-key
