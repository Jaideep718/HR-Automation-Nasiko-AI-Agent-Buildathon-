# HR Automation – Full Stack Environment Variables
# Copy this file to .env and fill in all values, then run:  docker compose up --build

# ── LLM ───────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your-openai-api-key-here
LLM_MODEL=gpt-4o

# HuggingFace (used by HR Helpdesk agent – leave blank if not using)
HF_TOKEN=
HF_BASE_URL=https://api-inference.huggingface.co/v1

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-role-key

# ── Email / SMTP (Gmail) ──────────────────────────────────────────────────────
SMTP_EMAIL=your-gmail@gmail.com
SMTP_PASSWORD=your-gmail-app-password

# ── Onboarding ────────────────────────────────────────────────────────────────
REMINDER_DAYS=7

# ── Offboarding ───────────────────────────────────────────────────────────────
HR_EMAIL=hr@yourcompany.com
COMPANY_NAME=Your Company Name

# ── HR Helpdesk (Pinecone RAG) ────────────────────────────────────────────────
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX=hr-policies
PINECONE_FAQ_INDEX=hr-faqs

# ── HR Helpdesk (PostgreSQL – only if using local DB for helpdesk) ────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=helpdesk
DB_USER=postgres
DB_PASSWORD=your-db-password
