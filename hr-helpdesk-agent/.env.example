# HR Helpdesk Agent Environment Configuration

# ======================
# Supabase Configuration (replaces direct PostgreSQL connection)
# Get from: Supabase Dashboard -> Project Settings -> API
# ======================
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_KEY=your_service_role_key_here

# ======================
# Pinecone Configuration (for RAG)
# ======================
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_INDEX=hr-policies
PINECONE_FAQ_INDEX=hr-faqs

# ======================
# LLM Configuration (HuggingFace)
# ======================
HF_TOKEN=your_huggingface_token
HF_BASE_URL=https://api-inference.huggingface.co/v1
LLM_MODEL=your-model-name

# ======================
# Embedding Model
# ======================
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
