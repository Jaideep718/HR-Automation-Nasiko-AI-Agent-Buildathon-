# =============================================================
# Master Orchestrator — Combined .env for full stack deployment
# Copy this file to .env and fill in your values
# =============================================================

# -----------------------------------------------
# LLM Configuration
# -----------------------------------------------
OPENAI_API_KEY=your-openai-api-key-here
LLM_MODEL=gpt-4o

# HuggingFace (optional — used by helpdesk agent)
HF_TOKEN=
HF_BASE_URL=https://api-inference.huggingface.co/v1

# -----------------------------------------------
# Supabase (used by onboarding + offboarding)
# -----------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-role-key

# -----------------------------------------------
# SMTP Email (used by onboarding + offboarding)
# -----------------------------------------------
SMTP_EMAIL=your-gmail@gmail.com
SMTP_PASSWORD=your-gmail-app-password

# -----------------------------------------------
# Onboarding-specific
# -----------------------------------------------
REMINDER_DAYS=1

# -----------------------------------------------
# Offboarding-specific
# -----------------------------------------------
HR_EMAIL=hr@yourcompany.com
COMPANY_NAME=Your Company Name

# -----------------------------------------------
# Helpdesk Agent (Pinecone RAG + PostgreSQL)
# -----------------------------------------------
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX=hr-policies
PINECONE_FAQ_INDEX=hr-faqs
DB_HOST=localhost
DB_PORT=5432
DB_NAME=helpdesk
DB_USER=postgres
DB_PASSWORD=your-db-password
